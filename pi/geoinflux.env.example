# -> /etc/buspi/geo.env (0600) on the Pi. Loaded by the geoinflux systemd unit.
# NOTE: systemd EnvironmentFile does NOT strip inline "# comments" — keep every
# comment on its own line so it never becomes part of a value.
INFLUXDB_TOKEN=your_influxdb_write_token
# The router's geolocd gpsd socket:
GPSD_ADDR=192.168.8.1:2947
INFLUX_URL=http://localhost:8086
INFLUX_ORG=home
INFLUX_BUCKET=buspi
UPLOAD_MIN_INTERVAL=30s
