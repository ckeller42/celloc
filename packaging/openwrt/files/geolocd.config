config geolocd 'main'
	option key ''             # OpenCelliD API key (required) — set this
	option poll_interval '60' # seconds between serving-cell polls
	option listen ':2947'     # gpsd socket bind address (LAN reachable; WAN blocked by firewall)
	option bus 'cpu'          # gl_modem bus
	option radio 'LTE'        # geolocation radio (v1: LTE)
	option runner 'glmodem'   # AT runner: glmodem | ubus
	option wifi_enable '1'
	option wifi_provider 'google'
	# Google Geolocation API key (required when wifi_provider='google'):
	# option google_key 'AIza...'
	option wifi_iface 'wlan0'
	option wifi_interval '300'
	option wifi_min_aps '2'
	# Unwired Labs region (only used when wifi_provider='unwiredlabs'; reuses 'key'):
	option ula_endpoint 'eu1'
