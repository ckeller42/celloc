config geolocd 'main'
	option listen ':2947'      # gpsd socket bind address (LAN reachable; WAN blocked by firewall)
	option bus 'cpu'           # gl_modem bus
	option runner 'glmodem'    # AT runner: glmodem | ubus
	# Position source: nearby WiFi APs + the modem's serving cell, blended by the
	# provider. Google is the default (WiFi included, free under ~10k req/mo).
	option wifi_enable '1'
	option wifi_provider 'google'
	# Google Geolocation API key (required when wifi_provider='google'):
	# option google_key 'AIza...'
	option wifi_iface 'wlan0'   # scan interface(s), space-separated for multiple radios
	option wifi_interval '300'  # seconds between scan+resolve cycles
	option wifi_min_aps '2'     # min APs before a WiFi query (cell alone still resolves)
	# Unwired Labs alternative (wifi_provider='unwiredlabs'): needs a paid WiFi plan.
	# 'key' is the OpenCelliD/Unwired Labs token; 'ula_endpoint' the region.
	# option key ''
	option ula_endpoint 'eu1'
