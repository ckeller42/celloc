config geolocd 'main'
	option key ''             # OpenCelliD API key (required) — set this
	option poll_interval '60' # seconds between serving-cell polls
	option listen ':2947'     # gpsd socket bind address (LAN reachable; WAN blocked by firewall)
	option bus 'cpu'          # gl_modem bus
	option radio 'LTE'        # geolocation radio (v1: LTE)
	option runner 'glmodem'   # AT runner: glmodem | ubus
